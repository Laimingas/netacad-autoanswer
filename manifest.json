{
  "manifest_version": 3,
  "name": "NetAcad AI Assistant",
  "version": "1.0.0",
  "description": "Scrapes NetAcad MCQ and selects answers via AI or question bank.",
  "permissions": ["storage", "commands", "scripting", "activeTab"],
  "host_permissions": ["https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "process-page-command": {
      "suggested_key": {
        "default": "Alt+M"
      },
      "description": "Process current NetAcad question"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["questions_bank.json"],
      "matches": ["<all_urls>"]
    }
  ]
}